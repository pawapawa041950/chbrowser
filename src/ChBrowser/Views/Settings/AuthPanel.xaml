<UserControl x:Class="ChBrowser.Views.Settings.AuthPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <StackPanel>

        <TextBlock Text="どんぐり (5ch) メール認証" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="0,0,0,12">
            メールアドレスを設定するとアプリ起動時に自動でログインを試行します。
            ログイン状態はメインウィンドウのステータスバーに表示されます。
        </TextBlock>

        <!-- メアド (TextBox はバインド可) -->
        <TextBlock Text="メールアドレス" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox Text="{Binding DonguriEmail, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=400}"
                 Width="320"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,12" />

        <!-- パスワード (PasswordBox は SecurityException 回避で Password 直接バインド不可、code-behind で連携) -->
        <TextBlock Text="パスワード" FontWeight="SemiBold" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordInput"
                     Width="320"
                     HorizontalAlignment="Left"
                     PasswordChanged="PasswordInput_PasswordChanged"
                     Margin="0,0,0,8" />
        <TextBlock TextWrapping="Wrap" Foreground="#A07020" FontSize="11"
                   Margin="0,0,0,16">
            ※ パスワードは現在 config.json に平文で保存されます (= ファイル盗難で第三者に読まれ得る)。
            機密性の高いアカウントの再利用は避けてください。
        </TextBlock>

        <!-- ログイン状態 + 手動ログインボタン -->
        <TextBlock Text="ログイン状態" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel HorizontalAlignment="Left" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right"
                    Content="今すぐログイン"
                    Padding="10,4"
                    Margin="8,0,0,0"
                    Command="{Binding LoginNowCommand}"
                    ToolTip="入力中の値を保存して、すぐにログイン試行する" />
            <Border Background="#F8F8F8" BorderBrush="#DDD" BorderThickness="1" Padding="10,6"
                    MinWidth="320">
                <TextBlock Text="{Binding DonguriLoginStatus}" TextWrapping="Wrap" />
            </Border>
        </DockPanel>

    </StackPanel>
</UserControl>
