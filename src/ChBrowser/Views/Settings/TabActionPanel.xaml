<UserControl x:Class="ChBrowser.Views.Settings.TabActionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <UserControl.Resources>

        <!-- スレ一覧タブ用アクション選択肢 (addFavorite / deleteLog 無し) -->
        <x:Array x:Key="ThreadListActions" Type="{x:Type sys:String}">
            <sys:String>none</sys:String>
            <sys:String>close</sys:String>
            <sys:String>refresh</sys:String>
            <sys:String>closeOthers</sys:String>
            <sys:String>closeLeft</sys:String>
            <sys:String>closeRight</sys:String>
        </x:Array>

        <!-- スレッドタブ用アクション選択肢 (全種類) -->
        <x:Array x:Key="ThreadActions" Type="{x:Type sys:String}">
            <sys:String>none</sys:String>
            <sys:String>close</sys:String>
            <sys:String>refresh</sys:String>
            <sys:String>addFavorite</sys:String>
            <sys:String>deleteLog</sys:String>
            <sys:String>closeOthers</sys:String>
            <sys:String>closeLeft</sys:String>
            <sys:String>closeRight</sys:String>
        </x:Array>

        <!-- 表示名マッピング (識別子文字列 → 日本語表示) -->
        <Style x:Key="ActionItemStyle" TargetType="ComboBoxItem">
            <Style.Triggers>
                <Trigger Property="Content" Value="none">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="動作なし" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Content" Value="close">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="閉じる" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Content" Value="refresh">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="更新" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Content" Value="addFavorite">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="お気に入りに追加" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Content" Value="deleteLog">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="ログを削除" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Content" Value="closeOthers">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="他をすべて閉じる" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Content" Value="closeLeft">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="左をすべて閉じる" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Content" Value="closeRight">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><TextBlock Text="右をすべて閉じる" /></DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- スレ一覧タブ -->
        <TextBlock Text="スレ一覧タブ" FontWeight="SemiBold" Margin="0,0,0,8" />
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="中クリック (ホイール)" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadListActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadListTabMiddleClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + 左クリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadListActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadListTabCtrlClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Shift + 左クリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="2" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadListActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadListTabShiftClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Alt + 左クリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="3" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadListActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadListTabAltClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="左ダブルクリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="4" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadListActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadListTabDoubleClickAction, Mode=TwoWay}" />
        </Grid>

        <!-- スレッドタブ -->
        <TextBlock Text="スレッドタブ" FontWeight="SemiBold" Margin="0,0,0,8" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="中クリック (ホイール)" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadTabMiddleClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + 左クリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadTabCtrlClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Shift + 左クリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="2" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadTabShiftClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Alt + 左クリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="3" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadTabAltClickAction, Mode=TwoWay}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="左ダブルクリック" VerticalAlignment="Center" Margin="0,2" />
            <ComboBox  Grid.Row="4" Grid.Column="1" Margin="0,2"
                       ItemsSource="{StaticResource ThreadActions}"
                       ItemContainerStyle="{StaticResource ActionItemStyle}"
                       SelectedItem="{Binding ThreadTabDoubleClickAction, Mode=TwoWay}" />
        </Grid>
    </StackPanel>
</UserControl>
