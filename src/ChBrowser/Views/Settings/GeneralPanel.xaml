<UserControl x:Class="ChBrowser.Views.Settings.GeneralPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <StackPanel>
        <TextBlock Text="HiDPI モード" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="高 DPI ディスプレイ用のスケーリング設定。変更には再起動が必要です。"
                   Foreground="#666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />
        <ComboBox SelectedValue="{Binding HiDpiMode, Mode=TwoWay}"
                  SelectedValuePath="Tag"
                  Width="260"
                  HorizontalAlignment="Left"
                  Margin="0,0,0,16">
            <ComboBoxItem Content="スケールしない (Unaware) — 既定" Tag="Unaware" />
            <ComboBoxItem Content="モニタごとに自動 (Per-Monitor V2)"   Tag="PerMonitorV2" />
        </ComboBox>

        <!-- 書き込みログ (kakikomi.txt) ON/OFF。即時反映。 -->
        <TextBlock Text="書き込みログ" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="0,0,0,4">
            書き込みが成功するたびに、JaneXeno 互換フォーマットで <Run FontFamily="Consolas">data/kakikomi.txt</Run> に追記します。
            ファイルは追記の瞬間だけ open するので、メモ帳等で同時に編集 / 保存しても問題ありません。
        </TextBlock>
        <CheckBox Content="kakikomi.txt に書き込み履歴を記録する"
                  IsChecked="{Binding EnableKakikomiLog, Mode=TwoWay}"
                  Margin="0,0,0,16" />

        <!-- タブの起動時復元。終了時にタブ一覧 (スレ一覧タブ + スレタブの両方) を保存し、起動時に同じ順で再オープン。 -->
        <TextBlock Text="セッション復元" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="0,0,0,4">
            アプリを終了した時に開いていたタブ (スレ一覧タブとスレッドタブの両方) を記憶し、
            次回起動時に同じ順番で開き直します。
        </TextBlock>
        <CheckBox Content="終了時に開いていたタブを次回起動時に開く"
                  IsChecked="{Binding RestoreOpenTabsOnStartup, Mode=TwoWay}"
                  Margin="0,0,0,4" />
    </StackPanel>
</UserControl>
