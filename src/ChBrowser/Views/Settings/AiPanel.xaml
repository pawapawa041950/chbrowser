<UserControl x:Class="ChBrowser.Views.Settings.AiPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             xmlns:conv="clr-namespace:ChBrowser.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <UserControl.Resources>
        <conv:LlmStatusToBrushConverter x:Key="LlmStatusBrush" />
    </UserControl.Resources>
    <StackPanel>

        <TextBlock Text="LLM 連携 (OpenAI 互換 API)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="0,0,0,12">
            OpenAI 互換の Chat Completions API に接続するための設定です。
            OpenAI 本体のほか、互換 API を提供するローカル LLM サーバ (LM Studio / Ollama / vLLM 等) も利用できます。
        </TextBlock>

        <!-- API URL -->
        <TextBlock Text="LLM API URL" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,4">
            base URL (例: https://api.openai.com/v1) でも、/chat/completions まで含む完全 URL でも可。
        </TextBlock>
        <TextBox Text="{Binding LlmApiUrl, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=400}"
                 Width="500"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,12" />

        <!-- API Key (PasswordBox: 肩越し閲覧対策。config.json には平文保存される点は注意書き参照) -->
        <TextBlock Text="LLM API Key" FontWeight="SemiBold" Margin="0,0,0,4" />
        <PasswordBox x:Name="ApiKeyInput"
                     Width="500"
                     HorizontalAlignment="Left"
                     PasswordChanged="ApiKeyInput_PasswordChanged"
                     Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap" Foreground="#A07020" FontSize="11" Margin="0,0,0,12">
            ※ API キーは現在 config.json に平文で保存されます。認証不要なローカル LLM サーバなら空欄で構いません。
        </TextBlock>

        <!-- モデル名 -->
        <TextBlock Text="LLM 名 (モデル名)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,4">
            リクエストの "model" に入る値 (例: gpt-4o-mini)。
        </TextBlock>
        <TextBox Text="{Binding LlmModel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=400}"
                 Width="320"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,12" />

        <!-- Context Size -->
        <TextBlock Text="Context Size (トークン数)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,4">
            モデルのコンテキスト長。今後の要約・翻訳機能で入力長の制御に使います。
        </TextBlock>
        <TextBox Text="{Binding LlmContextSize, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=400}"
                 Width="120"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,16" />

        <!-- 接続確認 -->
        <TextBlock Text="接続確認" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel HorizontalAlignment="Left" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right"
                    Content="接続確認"
                    Padding="14,4"
                    Margin="8,0,0,0"
                    Command="{Binding TestLlmConnectionCommand}"
                    ToolTip="入力中の値を保存して、OpenAI 互換 API に最小リクエストを送り接続可否を確認します" />
            <Border Background="#F8F8F8" BorderBrush="#DDD" BorderThickness="1" Padding="10,6"
                    MinWidth="380">
                <TextBlock Text="{Binding LlmConnectionStatus}"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Foreground="{Binding LlmConnectionStatus, Converter={StaticResource LlmStatusBrush}}" />
            </Border>
        </DockPanel>

    </StackPanel>
</UserControl>
