<UserControl x:Class="ChBrowser.Views.Settings.ImagePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <StackPanel>

        <TextBlock Text="画像キャッシュ上限 (MB)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="ローカル画像キャッシュの容量上限。超過すると LRU で古いものから自動削除。"
                   Foreground="#666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4" />
        <TextBox Text="{Binding CacheMaxMb, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=400}"
                 Width="100"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,12" />

        <TextBlock Text="現在のキャッシュサイズ" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="{Binding CacheSizeDisplay}"
                   FontFamily="Consolas, 'Courier New'"
                   Margin="0,0,0,16" />

        <StackPanel Orientation="Horizontal">
            <Button Content="キャッシュフォルダを開く"
                    Command="{Binding OpenCacheFolderCommand}"
                    Padding="10,4"
                    Margin="0,0,8,0" />
            <Button Content="キャッシュをクリア"
                    Command="{Binding ClearCacheCommand}"
                    Padding="10,4" />
        </StackPanel>

    </StackPanel>
</UserControl>
