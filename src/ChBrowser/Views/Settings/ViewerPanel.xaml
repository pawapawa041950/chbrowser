<UserControl x:Class="ChBrowser.Views.Settings.ViewerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <StackPanel>

        <TextBlock Text="タブのサムネイルサイズ (px)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="ビューアウィンドウのタブストリップに表示する画像サムネイルの一辺サイズ (正方形タイル)。"
                   Foreground="#666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <Grid Width="420" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    Minimum="40" Maximum="160"
                    TickFrequency="8" IsSnapToTickEnabled="True"
                    Value="{Binding ViewerThumbnailSize, Mode=TwoWay}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ViewerThumbnailSize, StringFormat={}{0} px}"
                       Width="60"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       FontFamily="Consolas, 'Courier New'" />
        </Grid>

    </StackPanel>
</UserControl>
