<UserControl x:Class="ChBrowser.Views.Settings.ViewerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">
    <StackPanel>

        <TextBlock Text="タブのサムネイルサイズ (px)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="ビューアウィンドウのタブストリップに表示する画像サムネイルの一辺サイズ (正方形タイル)。"
                   Foreground="#666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <Grid Width="420" HorizontalAlignment="Left" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    Minimum="40" Maximum="160"
                    TickFrequency="8" IsSnapToTickEnabled="True"
                    Value="{Binding ViewerThumbnailSize, Mode=TwoWay}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ViewerThumbnailSize, StringFormat={}{0} px}"
                       Width="60"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       FontFamily="Consolas, 'Courier New'" />
        </Grid>

        <!-- 画像詳細ペインの初期状態。次回ビューア起動時から反映 (= 既に開いている viewer は影響を受けない)。 -->
        <TextBlock Text="画像詳細ペイン" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap"
                   Foreground="#666"
                   Margin="0,0,0,4">
            ビューアウィンドウを開いたときに右側の画像詳細ペインを既定で開くか閉じるか。
            開閉は Tab キー / アコーディオン帯クリックで都度切替できます。
        </TextBlock>
        <CheckBox Content="ビューアを開いたとき画像詳細ペインを開いた状態にする"
                  IsChecked="{Binding ViewerDetailsPaneDefaultOpen, Mode=TwoWay}" />

    </StackPanel>
</UserControl>
