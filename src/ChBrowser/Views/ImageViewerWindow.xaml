<Window x:Class="ChBrowser.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        xmlns:ctrl="clr-namespace:ChBrowser.Controls"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ImageViewerViewModel}"
        Title="ChBrowser ビューア"
        Height="640" Width="900"
        UseLayoutRounding="True"
        Background="#1E1E1E">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 画像エリア右クリックで popup する ContextMenu (Phase 10b)。
             JS の contextmenu イベント → ViewerWebView_WebMessageReceived で
             ContextMenu.Tag に対象 URL を積んで PlacementMode=MousePoint で開く。 -->
        <ContextMenu x:Key="ImageContextMenu" x:Shared="False">
            <MenuItem Header="保存..."          Click="SaveImage_Click" />
            <MenuItem Header="URL をコピー"      Click="CopyImageUrl_Click" />
            <MenuItem Header="ブラウザで開く"    Click="OpenInBrowser_Click" />
        </ContextMenu>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Left"  Command="{Binding PrevTabCommand}" />
        <KeyBinding Key="Right" Command="{Binding NextTabCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CloseCurrentTabCommand}" />
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseCurrentTabCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCurrentTabCommand}" />
    </Window.InputBindings>

    <DockPanel LastChildFill="True">

        <!-- 上段: タブ見出し (ItemsSource = Tabs)。
             - 正方形に近いタイル形 (80x80) でサムネイルを表示
             - 多くなった時のために横スクロール可
             - ContextMenu/コンテンツは下段の ItemsControl が並列描画
             - サムネはまず Url を直接 (WPF が HTTP fetch)、ロード完了で
               file://キャッシュパスに切り替え (pixiv の Referer 制約等を回避) -->
        <TabControl DockPanel.Dock="Top"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Background="#2A2A2A"
                    BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="#2A2A2A">
                        <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                    </ScrollViewer>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Margin"      Value="2" />
                    <Setter Property="Padding"     Value="0" />
                    <Setter Property="Background"  Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="3">
                                    <ContentPresenter ContentSource="Header" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#4FC3F7" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#3A3A3A" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ImageViewerTabViewModel}">
                    <Grid x:Name="tile"
                          Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                          Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                          ToolTip="{Binding Url}">
                        <Image Source="{Binding ThumbnailPath}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <!-- 閉じるボタン (タイルにマウスが乗ったときだけ表示) -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="2"
                                Width="18" Height="18"
                                Padding="0"
                                Content="×" FontSize="12"
                                Background="#A0000000"
                                BorderThickness="0"
                                Foreground="White"
                                Cursor="Hand"
                                Command="{Binding CloseCommand}"
                                ToolTip="閉じる">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=tile}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- 下部にファイル名 (半透明オーバーレイ) -->
                        <Border VerticalAlignment="Bottom"
                                Background="#A0000000"
                                Padding="3,1">
                            <TextBlock Text="{Binding Header}"
                                       Foreground="#EEE"
                                       FontSize="9"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>

        <!-- 下段: 各タブが専属 WebView2 を持ち、Visibility で選択タブだけ可視に。
             スレ表示と同じパターン。これでタブ切替時にズーム/パン状態が保持される。 -->
        <ItemsControl ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ImageViewerTabViewModel}">
                    <wv2:WebView2 ctrl:WebView2Helper.ImageUrl="{Binding Url}"
                                  WebMessageReceived="ViewerWebView_WebMessageReceived"
                                  Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </DockPanel>
</Window>
