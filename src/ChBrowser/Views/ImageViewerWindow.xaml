<Window x:Class="ChBrowser.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        xmlns:ctrl="clr-namespace:ChBrowser.Controls"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ImageViewerViewModel}"
        Title="ChBrowser ビューア"
        Height="640" Width="900"
        UseLayoutRounding="True"
        Background="#1E1E1E">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 画像エリア右クリックで popup する ContextMenu (Phase 10b)。
             JS の contextmenu イベント → ViewerWebView_WebMessageReceived で
             ContextMenu.Tag に対象 URL を積んで PlacementMode=MousePoint で開く。 -->
        <ContextMenu x:Key="ImageContextMenu" x:Shared="False"
                     Opened="ImageContextMenu_Opened">
            <MenuItem Header="画像を原寸表示"    Click="ZoomActual_Click" />
            <MenuItem Header="ウィンドウに合わせる" Click="ZoomFit_Click" />
            <MenuItem Header="全画面表示" IsCheckable="True"
                      Tag="fullscreen"
                      Click="Fullscreen_Click" />
            <Separator />
            <MenuItem Header="保存..."          Click="SaveImage_Click" />
            <MenuItem Header="URL をコピー"      Click="CopyImageUrl_Click" />
            <MenuItem Header="ブラウザで開く"    Click="OpenInBrowser_Click" />
        </ContextMenu>
    </Window.Resources>

    <!-- Phase 16+: 旧 KeyBindings は ShortcutManager に統合した (shortcuts.json で管理)。
         デフォルトでは Esc=閉じる / Ctrl+S=保存 / ←=前 / →=次 を ShortcutRegistry に既定値として設定。 -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!-- アコーディオンバー: 常時 16px で表示。クリックで詳細ペインを開閉する。
                 閉じている時はこの帯だけが画像エリアと詳細ペインの間に残り、再度クリックで開く。 -->
            <ColumnDefinition Width="Auto" />
            <!-- 画像詳細ペイン (Tab で表示/非表示切替)。デフォルト幅 320 = 開いた状態 (= 起動時から開く)。
                 ToggleDetailsPane() で 320 ↔ 0 を切り替える。GridSplitter は付けず、固定幅でシンプルに。 -->
            <ColumnDefinition x:Name="DetailsColumn" Width="320" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" LastChildFill="True">

        <!-- 上段: タブ見出し (ItemsSource = Tabs)。
             - 正方形に近いタイル形 (80x80) でサムネイルを表示
             - 多くなった時のために横スクロール可
             - ContextMenu/コンテンツは下段の ItemsControl が並列描画
             - サムネはまず Url を直接 (WPF が HTTP fetch)、ロード完了で
               file://キャッシュパスに切り替え (pixiv の Referer 制約等を回避) -->
        <TabControl x:Name="TabStrip"
                    DockPanel.Dock="Top"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Background="#2A2A2A"
                    BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="#2A2A2A">
                        <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                    </ScrollViewer>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Margin"      Value="2" />
                    <Setter Property="Padding"     Value="0" />
                    <Setter Property="Background"  Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="2"
                                        CornerRadius="3">
                                    <ContentPresenter ContentSource="Header" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#4FC3F7" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#3A3A3A" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ImageViewerTabViewModel}">
                    <Grid x:Name="tile"
                          Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                          Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                          ToolTip="{Binding Url}">
                        <!-- 動画タブはサムネ画像が空 (= キャプチャ前 or CORS で取れない) のことがあるので、
                             背景に黒タイルを敷いて視認性を保つ。画像タブでは Image が覆い隠す。 -->
                        <Rectangle Fill="#222"
                                   Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}}" />
                        <Image Source="{Binding ThumbnailPath}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <!-- 動画タブの ▶ オーバーレイ (デザイン目的のみ、クリックは Grid 全体に届く)。
                             半透明黒の丸 + 中央の三角。タブ左下に小さく表示して「これは動画」と示す。
                             Margin の bottom=14 はファイル名ストリップ (= 下端の半透明 Border、約 12px) を
                             避けるためのオフセット。 -->
                        <Grid Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}}"
                              IsHitTestVisible="False"
                              HorizontalAlignment="Left" VerticalAlignment="Bottom"
                              Margin="3,0,0,14"
                              Width="20" Height="20">
                            <Ellipse Fill="#A0000000" />
                            <!-- 三角形は Polygon (= 右向き ▶)。サイズは Ellipse 内に収まるよう調整 (20x20)。 -->
                            <Polygon Points="7,5 7,15 15,10"
                                     Fill="White"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <!-- 閉じるボタン (タイルにマウスが乗ったときだけ表示) -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="2"
                                Width="18" Height="18"
                                Padding="0"
                                Content="×" FontSize="12"
                                Background="#A0000000"
                                BorderThickness="0"
                                Foreground="White"
                                Cursor="Hand"
                                Command="{Binding CloseCommand}"
                                ToolTip="閉じる">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=tile}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- 下部にファイル名 (半透明オーバーレイ) -->
                        <Border VerticalAlignment="Bottom"
                                Background="#A0000000"
                                Padding="3,1">
                            <TextBlock Text="{Binding Header}"
                                       Foreground="#EEE"
                                       FontSize="9"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>

        <!-- 下段: 各タブが専属 WebView2 を持ち、Visibility で選択タブだけ可視に。
             スレ表示と同じパターン。これでタブ切替時にズーム/パン状態が保持される。 -->
        <ItemsControl ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ImageViewerTabViewModel}">
                    <!-- Phase 6: PlaybackUrl は通常 Url と同一だが、動画キャッシュヒット時は
                         仮想ホスト URL (https://chbrowser-cache.local/videos/...) に差替えられる。
                         InitializeForVideo() がタブ生成直後にこれをセットする。 -->
                    <wv2:WebView2 ctrl:WebView2Helper.ImageUrl="{Binding PlaybackUrl}"
                                  ctrl:WebView2Helper.ZoomModePush="{Binding PendingZoomMode}"
                                  WebMessageReceived="ViewerWebView_WebMessageReceived"
                                  Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        </DockPanel>

        <!-- アコーディオンバー (col 1)。常に表示され、クリックで詳細ペインを開閉する。
             視覚的には縦長の細い帯 + 中央にシェブロン (▶/◀)。マウスオーバーで色が変わる。 -->
        <Border Grid.Column="1"
                x:Name="AccordionBar"
                Width="16"
                Background="#2A2A2A"
                BorderBrush="#444"
                BorderThickness="1,0"
                Cursor="Hand"
                MouseLeftButtonUp="AccordionBar_MouseLeftButtonUp"
                ToolTip="画像詳細ペインを開閉">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3A3A3A" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock x:Name="AccordionChevron"
                       Text="▶"
                       Foreground="#AAA"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <!-- 画像詳細ペイン (Tab で表示/非表示)。
             AiImageMetadataService の結果を ImageViewerWindow.xaml.cs から PostWebMessageAsJson で push する。 -->
        <Border Grid.Column="2"
                BorderBrush="#444"
                BorderThickness="1,0,0,0"
                Background="#1E1E1E">
            <wv2:WebView2 x:Name="DetailsWebView" />
        </Border>
    </Grid>
</Window>
