<Window x:Class="ChBrowser.Views.BoardPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="板の選択"
        Width="420" Height="520"
        MinWidth="320" MinHeight="320"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <DockPanel LastChildFill="True" Margin="10">

        <!-- 下: OK / キャンセル -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OkButton"
                        Content="OK"
                        Width="80"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="OkButton_Click"
                        Margin="0,0,8,0" />
                <Button Content="キャンセル"
                        Width="80"
                        IsCancel="True" />
            </StackPanel>
        </Border>

        <!-- 上: 検索ボックス -->
        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Margin="0,0,0,6"
                 Padding="4,3"
                 InputMethod.IsInputMethodEnabled="False"
                 InputMethod.PreferredImeState="Off"
                 InputMethod.PreferredImeConversionMode="Alphanumeric"
                 TextChanged="SearchBox_TextChanged"
                 PreviewKeyDown="SearchBox_PreviewKeyDown" />

        <!-- 中央: 結果リスト -->
        <ListBox x:Name="ResultList"
                 DisplayMemberPath="DisplayName"
                 SelectionChanged="ResultList_SelectionChanged"
                 MouseDoubleClick="ResultList_MouseDoubleClick" />
    </DockPanel>
</Window>
