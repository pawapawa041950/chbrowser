<UserControl x:Class="ChBrowser.Views.Panes.ThreadListPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             xmlns:ctrl="clr-namespace:ChBrowser.Controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             GotKeyboardFocus="Pane_GotKeyboardFocus"
             PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- スレ一覧タブ右クリックメニュー (Phase 21)。
             ThreadListTabItem_MouseRightButtonUp が PlacementTarget + DataContext を積んで popup する。 -->
        <ContextMenu x:Key="ThreadListTabContextMenu" x:Shared="False"
                     Opened="ThreadListTabContextMenu_Opened">
            <MenuItem Tag="fav" Header="お気に入りに追加" Click="ThreadListTabFav_Click" />
            <Separator />
            <MenuItem Header="コピー">
                <MenuItem               Header="タイトルコピー"        Click="ThreadListTabCopyTitle_Click" />
                <MenuItem Tag="copyUrl" Header="URLコピー"             Click="ThreadListTabCopyUrl_Click" />
                <MenuItem Tag="copyUrl" Header="タイトルとURLコピー"   Click="ThreadListTabCopyTitleAndUrl_Click" />
            </MenuItem>
        </ContextMenu>

        <!-- スレ一覧の各行 (= WebView2 内の <tr>) を右クリックしたときに WPF 側で popup するメニュー。
             スレ表示タブの右クリックメニューと同じ並び。「板を開く」だけ除外している (= 行のスレが
             属する板は今いるスレ一覧そのものなので意味が無いため)。
             DataContext には JS から飛んできた {host, directoryName, key, title} を ThreadListRowMenuContext
             として詰めて placement 直前にセットする。 -->
        <ContextMenu x:Key="ThreadListRowContextMenu" x:Shared="False"
                     Opened="ThreadListRowContextMenu_Opened">
            <MenuItem Tag="fav" Header="お気に入りに追加" Click="ThreadListRowFav_Click" />
            <Separator />
            <MenuItem Header="コピー">
                <MenuItem Header="タイトルコピー"        Click="ThreadListRowCopyTitle_Click" />
                <MenuItem Header="URLコピー"             Click="ThreadListRowCopyUrl_Click" />
                <MenuItem Header="タイトルとURLコピー"   Click="ThreadListRowCopyTitleAndUrl_Click" />
            </MenuItem>
            <Separator />
            <MenuItem Header="次スレ候補検索" Click="ThreadListRowFindNext_Click" />
            <MenuItem Header="ログ削除"       Click="ThreadListRowDeleteLog_Click" />
        </ContextMenu>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource PaneBorderBrush}" BorderThickness="1" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ペインヘッダ + ツールバー (新規スレ立て等)。Phase 23: ヘッダ部分がドラッグハンドル。 -->
        <Border x:Name="HeaderBar"
                Grid.Row="0"
                Background="{StaticResource PaneHeaderBackground}"
                BorderBrush="{StaticResource PaneBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="4,2">
                <TextBlock DockPanel.Dock="Left" Text="スレッド一覧" Padding="2,2,8,2" VerticalAlignment="Center" FontWeight="SemiBold" />
                <!-- ボタン群は右端固定。SearchBoxToggle はその間 (= last child fill) に配置して
                     ペイン幅が狭くても × ボタンが画面内に残るようにする。 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- 更新 (= 選択中のスレ一覧タブを再取得)。タブ種別 (板 / 全ログ / お気に入り) を問わず動作する。
                         SelectedThreadListTab が null なら無効化。 -->
                    <Button Click="RefreshThreadListButton_Click"
                            ToolTip="このスレ一覧タブを更新">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedThreadListTab}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="🔄" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>

                    <!-- 板アクション (新規スレ立て) - 板タブのときだけ有効。 -->
                    <Button Click="NewThreadButton_Click"
                            ToolTip="この板に新規スレッドを立てる">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                <Setter Property="IsEnabled" Value="False" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedThreadListTab.IsBoardTab}" Value="True">
                                        <Setter Property="IsEnabled" Value="True" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid Width="16" Height="16">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.4"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M 3,3 L 11,3 L 13,5 L 13,13 L 3,13 Z M 8,7 L 8,11 M 6,9 L 10,9" />
                        </Grid>
                    </Button>

                    <!-- お気に入りトグル (★) - 板タブのときだけ有効。
                         登録済みなら背景強調 + ToolTip 「外す」。スレ表示ペインの ★ ボタンと同じ見た目。 -->
                    <Button Click="ToggleBoardFavoriteButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                <Setter Property="IsEnabled" Value="False" />
                                <Setter Property="ToolTip"   Value="この板をお気に入りに追加" />
                                <Style.Triggers>
                                    <!-- 板タブで未登録: 有効 + 「追加」ツールチップ -->
                                    <DataTrigger Binding="{Binding SelectedThreadListTab.IsBoardTab}" Value="True">
                                        <Setter Property="IsEnabled" Value="True" />
                                    </DataTrigger>
                                    <!-- 既に登録済み: ★ボタン背景強調 + 「外す」ツールチップ。
                                         IsEnabled は上のトリガで True 確定済み (= 板タブ)。 -->
                                    <DataTrigger Binding="{Binding SelectedThreadListTab.IsBoardFavorited}" Value="True">
                                        <Setter Property="ToolTip"     Value="この板をお気に入りから外す" />
                                        <Setter Property="Background"  Value="#CCE5FF" />
                                        <Setter Property="BorderBrush" Value="#88B0DD" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="★" FontSize="14" Foreground="#e6b800"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <!-- 絞り込み検索: タイトルとボタン群の間の残りスペースを fill (= 最後の child)。
                     SelectedThreadListTab.SearchQuery と双方向 bind、per-tab で復元。 -->
                <ctrl:SearchBoxToggle Margin="0,0,6,0"
                                      HintText="タイトルにこの文字列を含むスレッドだけ表示 (空欄でフィルタ解除)"
                                      Text="{Binding SelectedThreadListTab.SearchQuery, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}">
                    <ctrl:SearchBoxToggle.Style>
                        <Style TargetType="ctrl:SearchBoxToggle">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedThreadListTab}" Value="{x:Null}">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ctrl:SearchBoxToggle.Style>
                </ctrl:SearchBoxToggle>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1"
                    ItemsSource="{Binding ThreadListTabs}"
                    SelectedItem="{Binding SelectedThreadListTab}"
                    BorderThickness="0"
                    Margin="1,0,1,0"
                    MinHeight="24"><!-- タブ 0 件でも 1 段分の高さを維持 -->
            <!-- WrapPanel で「複数行 wrap」を実現。タブが画面幅を超えると次の行に折り返す。
                 デフォルトの TabPanel は環境によって wrap が機能しないことがあったため明示的に WrapPanel に変更。 -->
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <WrapPanel IsItemsHost="True" Orientation="Horizontal"
                               Background="{x:Static SystemColors.ControlBrush}" />
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <!-- タブ幅は MaxWidth で「上限」として bind (= 短いタイトルは自然な幅で縮み、長いタイトルは
                         設定値でカットして次行 wrap)。MinWidth で潰れすぎを防ぐ。 -->
                    <Setter Property="MaxWidth"
                            Value="{Binding DataContext.ThreadListTabWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <Setter Property="MinWidth" Value="60" />
                    <!-- タブのクリック (中/Ctrl+左/Shift+左/Alt+左/ダブル) は ShortcutManager の
                         PreviewMouseDown ハンドラがカテゴリ「スレ一覧のタブ領域」として dispatch するので、
                         pane 側で直接拾う必要は無い (= 二重発火を避けるため EventSetter は外している)。 -->
                    <EventSetter Event="MouseRightButtonUp"   Handler="ThreadListTabItem_MouseRightButtonUp" />
                </Style>
            </TabControl.ItemContainerStyle>
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ThreadListTabViewModel}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="×"
                                Command="{Binding CloseCommand}"
                                Width="16" Height="16"
                                Margin="6,0,0,0"
                                Padding="0"
                                FontSize="10"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="閉じる" />
                        <TextBlock Text="{Binding Header}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Header}" />
                    </DockPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding ThreadListTabs}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ThreadListTabViewModel}">
                    <wv2:WebView2 ctrl:WebView2Helper.Html="{Binding Html}"
                                  ctrl:WebView2Helper.ItemsHtmlPatch="{Binding ItemsHtmlPatch}"
                                  ctrl:WebView2Helper.LogMarkUpdate="{Binding LogMarkUpdate}"
                                  ctrl:WebView2Helper.FavoritedUpdate="{Binding FavoritedUpdate}"
                                  ctrl:WebView2Helper.ThreadListSearchPush="{Binding SearchQuery}"
                                  ctrl:WebView2Helper.PaneConfigJson="{Binding DataContext.ThreadListConfigJson, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  ctrl:WebView2Helper.PaneShortcutsJson="{Binding DataContext.ThreadListShortcutsJson, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  WebMessageReceived="ThreadListWebView_WebMessageReceived"
                                  Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
    </Border>
</UserControl>
