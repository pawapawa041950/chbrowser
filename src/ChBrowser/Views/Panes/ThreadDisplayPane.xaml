<UserControl x:Class="ChBrowser.Views.Panes.ThreadDisplayPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ChBrowser.ViewModels"
             xmlns:ctrl="clr-namespace:ChBrowser.Controls"
             xmlns:conv="clr-namespace:ChBrowser.Converters"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             GotKeyboardFocus="Pane_GotKeyboardFocus"
             PreviewMouseLeftButtonDown="Pane_PreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:LogMarkStateToBrushConverter x:Key="LogMarkBrush" />

        <!-- スレ表示タブ右クリックメニュー (Phase 21)。 -->
        <ContextMenu x:Key="ThreadTabContextMenu" x:Shared="False"
                     Opened="ThreadTabContextMenu_Opened">
            <MenuItem Tag="fav" Header="お気に入りに追加" Click="ThreadTabFav_Click" />
            <Separator />
            <MenuItem Header="板を開く" Click="ThreadTabOpenBoard_Click" />
            <Separator />
            <MenuItem Header="コピー">
                <MenuItem Header="タイトルコピー"        Click="ThreadTabCopyTitle_Click" />
                <MenuItem Header="URLコピー"             Click="ThreadTabCopyUrl_Click" />
                <MenuItem Header="タイトルとURLコピー"   Click="ThreadTabCopyTitleAndUrl_Click" />
            </MenuItem>
            <Separator />
            <MenuItem Header="次スレ候補検索" Click="ThreadTabFindNext_Click" />
            <MenuItem Header="ログ削除"       Click="ThreadTabDeleteLog_Click" />
        </ContextMenu>

        <!-- レス番号クリック / 右クリックで開くコンテキストメニュー (Phase 25 で HTML 版から WPF ネイティブに移行)。
             JS の postNoContextMenu メッセージを受けて HandlePostNoContextMenu が IsOpen=true で開く。
             Opened イベントで「自分の書き込み」label と NG サブ項目の値表示 + 有効/無効を動的に書き換える。 -->
        <ContextMenu x:Key="PostNoContextMenu" x:Shared="False"
                     Opened="PostNoContextMenu_Opened">
            <MenuItem Tag="jump"  Header="このレスに飛ぶ"        Click="PostNoJump_Click" />
            <Separator />
            <MenuItem Tag="reply" Header="返信"                  Click="PostNoReply_Click" />
            <MenuItem Tag="own"   Header="自分の書き込みにする"  Click="PostNoToggleOwn_Click" />
            <Separator />
            <MenuItem Header="NG 登録">
                <MenuItem Tag="ngName"    Click="PostNoNgName_Click" />
                <MenuItem Tag="ngId"      Click="PostNoNgId_Click" />
                <MenuItem Tag="ngWatchoi" Click="PostNoNgWatchoi_Click" />
            </MenuItem>
        </ContextMenu>

        <!-- URL (本文中のテキストリンク / 画像/動画サムネ) 右クリック用コンテキストメニュー。
             JS の urlContextMenu メッセージを受けて HandleUrlContextMenu が IsOpen=true で開く。
             対象 URL は ContextMenu.Tag に積んでクリックハンドラから読み出す。
             「ビューアで開く」は画像/動画サムネ右クリック時のみ Visible (HandleUrlContextMenu で切替)。 -->
        <ContextMenu x:Key="UrlContextMenu" x:Shared="False">
            <!-- ビューア項目は Tag="openInViewer" で HandleUrlContextMenu から識別 (x:Name は
                 x:Shared="False" だと毎回違う名前スコープに登録されるため Tag のほうが扱いやすい)。 -->
            <MenuItem Header="ビューアで開く"
                      Tag="openInViewer"
                      Click="OpenInViewer_Click"
                      Visibility="Collapsed" />
            <!-- キャッシュ削除: 動画スロット (mediaType=='video') 右クリック時のみ表示。
                 VideoThumb + Video のキャッシュエントリ + DL 失敗状態をクリアする。 -->
            <MenuItem Header="キャッシュ削除"
                      Tag="deleteVideoCache"
                      Click="DeleteVideoCache_Click"
                      Visibility="Collapsed" />
            <MenuItem Header="リンクをコピー" Click="UrlCopy_Click" />
        </ContextMenu>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource PaneBorderBrush}" BorderThickness="1" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ペインヘッダ + ツールバー (差分取得 / 書込 / モード切替 / 削除 / お気に入り)。Phase 23 で
             旧 MainWindow の中央ツールバー (スレ一覧とスレ表示の間) を本ペインのトップに統合。 -->
        <Border x:Name="HeaderBar"
                Grid.Row="0"
                Background="{StaticResource PaneHeaderBackground}"
                BorderBrush="{StaticResource PaneBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="4,2">
                <TextBlock DockPanel.Dock="Left" Text="スレッド表示" Padding="2,2,8,2" VerticalAlignment="Center" FontWeight="SemiBold" />
                <!-- ボタン群は右端に固定。SearchBoxToggle を DockPanel の last child (= 残り幅を fill)
                     にすることで、ペイン幅が狭くても × ボタンが画面内に確実に残る。 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedThreadTab}" Value="{x:Null}">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- フィルタトグル: 人気レス / 画像レス。両方 ON で OR (= どちらかに該当なら表示)。 -->
                    <ToggleButton Style="{StaticResource ToolbarToggleIconButton}"
                                  IsChecked="{Binding SelectedThreadTab.IsPopularFilterOn}"
                                  ToolTip="人気のレス (返信が多いレス + ツリーモードではその配下) のみ表示。画像トグルと OR 動作">
                        <TextBlock Text="👍" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource ToolbarToggleIconButton}"
                                  IsChecked="{Binding SelectedThreadTab.IsMediaFilterOn}"
                                  ToolTip="画像 / 動画 URL を含むレスのみ表示。人気トグルと OR 動作">
                        <TextBlock Text="🖼" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ToggleButton>

                    <!-- 差分取得 -->
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Command="{Binding SelectedThreadTab.RefreshCommand}"
                            ToolTip="このスレの差分を取得 (新着レスを末尾に追加)">
                        <TextBlock Text="🔄" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>

                    <!-- 書き込み -->
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Command="{Binding SelectedThreadTab.WriteCommand}"
                            ToolTip="このスレに書き込む">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Data="M 3,13 L 3,16 L 6,16 L 14,8 L 11,5 L 3,13 M 11,5 L 13,3 L 16,6 L 14,8" />
                    </Button>

                    <!-- 表示モード切替 -->
                    <Button Command="{Binding SelectedThreadTab.CycleViewModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                <Setter Property="ToolTip" Value="表示モードを切替" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}" Value="{x:Static vm:ThreadViewMode.Flat}">
                                        <Setter Property="ToolTip" Value="現在: レス順表示 (クリック → ツリー (重複あり))" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}" Value="{x:Static vm:ThreadViewMode.Tree}">
                                        <Setter Property="ToolTip" Value="現在: ツリー表示 (重複あり) (クリック → ツリー (重複なし))" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}" Value="{x:Static vm:ThreadViewMode.DedupTree}">
                                        <Setter Property="ToolTip" Value="現在: ツリー表示 (重複なし) (クリック → レス順表示)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid Width="16" Height="20">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M3,5 L13,5 M3,10 L13,10 M3,15 L13,15">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode, FallbackValue={x:Static vm:ThreadViewMode.Flat}}"
                                                         Value="{x:Static vm:ThreadViewMode.Flat}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M5,3 L5,17 M5,7 L11,7 M5,12 L11,12 M5,16 L11,16">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}"
                                                         Value="{x:Static vm:ThreadViewMode.Tree}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.4"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M3,3 L3,6 L6,6 L6,10 L9,10 L9,14 L12,14">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}"
                                                         Value="{x:Static vm:ThreadViewMode.DedupTree}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Grid>
                    </Button>

                    <!-- ログ削除 -->
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Command="{Binding SelectedThreadTab.DeleteCommand}"
                            ToolTip="このスレのログを削除してタブを閉じる">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2"
                              StrokeLineJoin="Round"
                              Data="M6,3 L10,3 L10,5 L6,5 Z M3,5 L13,5 M5,5 L5,16 L11,16 L11,5 M7,8 L7,13 M9,8 L9,13" />
                    </Button>

                    <!-- お気に入りトグル (★) -->
                    <Button Command="{Binding SelectedThreadTab.AddToFavoritesCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                <Setter Property="ToolTip" Value="このスレをお気に入りに追加" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedThreadTab.IsFavorited}" Value="True">
                                        <Setter Property="ToolTip"     Value="このスレをお気に入りから外す" />
                                        <Setter Property="Background"  Value="#CCE5FF" />
                                        <Setter Property="BorderBrush" Value="#88B0DD" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="★" FontSize="14" Foreground="#e6b800"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <!-- 絞り込み検索: ヘッダの「タイトル」と「ボタン群」の間の残りスペースを fill する。
                     ペイン幅が狭くなっても × ボタン (= SearchBoxToggle 内で Dock=Right) が画面内に残る。
                     SelectedThreadTab.SearchQuery と双方向 bind、per-tab で復元。 -->
                <ctrl:SearchBoxToggle Margin="0,0,6,0"
                                      HintText="本文 / 名前行に文字列を含むレスだけ表示 (空欄でフィルタ解除)"
                                      Text="{Binding SelectedThreadTab.SearchQuery, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}">
                    <ctrl:SearchBoxToggle.Style>
                        <Style TargetType="ctrl:SearchBoxToggle">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedThreadTab}" Value="{x:Null}">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ctrl:SearchBoxToggle.Style>
                </ctrl:SearchBoxToggle>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1"
                    ItemsSource="{Binding ThreadTabs}"
                    SelectedItem="{Binding SelectedThreadTab}"
                    BorderThickness="0"
                    Margin="1,0,1,0"
                    MinHeight="24"><!-- タブ 0 件でも 1 段分の高さを維持 (= 中クリック復元の hit area を残す) -->
            <!-- WrapPanel で「複数行 wrap」を実現。タブが画面幅を超えると次の行に折り返す。
                 デフォルトの TabPanel は環境によって wrap が機能しないことがあったため明示的に WrapPanel に変更。 -->
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <WrapPanel IsItemsHost="True" Orientation="Horizontal"
                               Background="{x:Static SystemColors.ControlBrush}" />
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <!-- タブ幅は MaxWidth で「上限」として bind (= 短いタイトルは自然な幅で縮み、長いタイトルは
                         設定値でカットして次行 wrap)。MinWidth で潰れすぎを防ぐ。 -->
                    <Setter Property="MaxWidth"
                            Value="{Binding DataContext.ThreadTabWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <Setter Property="MinWidth" Value="60" />
                    <!-- タブのクリック (中/Ctrl+左/Shift+左/Alt+左/ダブル) は ShortcutManager の
                         PreviewMouseDown ハンドラがカテゴリ「スレッドタブ表示領域」として dispatch するので、
                         pane 側で直接拾う必要は無い (= 二重発火を避けるため EventSetter は外している)。 -->
                    <EventSetter Event="MouseRightButtonUp"   Handler="ThreadTabItem_MouseRightButtonUp" />
                </Style>
            </TabControl.ItemContainerStyle>
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ThreadTabViewModel}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="×"
                                Command="{Binding CloseCommand}"
                                Width="16" Height="16"
                                Margin="6,0,0,0"
                                Padding="0"
                                FontSize="10"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="閉じる" />
                        <Grid DockPanel.Dock="Left" Width="14" Height="14" Margin="2,0,4,0" VerticalAlignment="Center">
                            <TextBlock Text="★" FontSize="14" Foreground="#B3E6B800"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding IsFavorited, Converter={StaticResource BoolToVis}}" />
                            <Ellipse Width="8" Height="8"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding State, Converter={StaticResource LogMarkBrush}}" />
                        </Grid>
                        <!-- Header はタブ表示用に事前短縮されているので、ToolTip は元タイトルを保持する Title を使う。 -->
                        <TextBlock Text="{Binding Header}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Title}" />
                    </DockPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding ThreadTabs}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ThreadTabViewModel}">
                    <wv2:WebView2 ctrl:WebView2Helper.AppendBatch="{Binding LatestAppendBatch}"
                                  ctrl:WebView2Helper.OwnPostsUpdate="{Binding OwnPostsUpdate}"
                                  ctrl:WebView2Helper.MarkPostNumberPush="{Binding MarkPostNumber}"
                                  ctrl:WebView2Helper.FilterPush="{Binding Filter}"
                                  ctrl:WebView2Helper.ViewMode="{Binding ViewMode}"
                                  ctrl:WebView2Helper.HidePostsPush="{Binding PendingHidePostNumbers}"
                                  ctrl:WebView2Helper.ScrollToPostPush="{Binding PendingScrollToPost}"
                                  ctrl:WebView2Helper.ThreadConfigJson="{Binding DataContext.ThreadConfigJson, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  ctrl:WebView2Helper.ThreadShortcutsJson="{Binding DataContext.ThreadShortcutsJson, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  WebMessageReceived="ThreadViewWebView_WebMessageReceived"
                                  Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
    </Border>
</UserControl>
