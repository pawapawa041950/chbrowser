<Window x:Class="ChBrowser.Views.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ShortcutsWindowViewModel}"
        Title="ChBrowser ショートカット &amp; マウスジェスチャー"
        Width="780" Height="600"
        MinWidth="560" MinHeight="360"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ショートカット / ジェスチャー セルをボタン風に表示するスタイル。
             空文字なら "—" を表示してクリックで「未設定 → 入力受付」を将来開く想定 (現状はスタブ)。 -->
        <Style x:Key="BindingButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding"                    Value="8,3" />
            <Setter Property="MinWidth"                   Value="120" />
            <Setter Property="Background"                 Value="#F5F5F7" />
            <Setter Property="BorderBrush"                Value="#D0D0D5" />
            <Setter Property="BorderThickness"            Value="1" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#E8F0FA" />
                    <Setter Property="BorderBrush" Value="#1E88E5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- グループヘッダ (= カテゴリ名) のスタイル。 -->
        <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#333" />
            <Setter Property="Margin"     Value="6,12,6,4" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- 下部: 未保存インジケータ + 保存 / 閉じる -->
        <Border DockPanel.Dock="Bottom"
                Background="{x:Static SystemColors.ControlBrush}"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#C77700"
                           Text="● 未保存の変更があります"
                           Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVis}}" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="保存"
                            Width="90"
                            Margin="0,0,8,0"
                            IsDefault="True"
                            Click="SaveButton_Click" />
                    <Button Content="閉じる"
                            Width="90"
                            IsCancel="True"
                            Click="CloseButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 上部: 検索ボックス -->
        <Border DockPanel.Dock="Top"
                Padding="10,8"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="操作を検索:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         Padding="4,3"
                         VerticalContentAlignment="Center" />
            </Grid>
        </Border>

        <!-- メイン: カテゴリでグルーピングした ListView -->
        <ListView ItemsSource="{Binding ItemsView}"
                  BorderThickness="0"
                  Background="White"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ShortcutItem}">
                    <Grid Margin="20,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"   />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Action}"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Style="{StaticResource BindingButtonStyle}"
                                Margin="8,2,4,2"
                                ToolTip="ショートカットを変更"
                                Click="EditShortcut_Click">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Shortcut}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Shortcut}" Value="">
                                                <Setter Property="Text"       Value="—" />
                                                <Setter Property="Foreground" Value="#999" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource BindingButtonStyle}"
                                Margin="4,2,4,2"
                                ToolTip="マウス操作を変更 (左/右/中クリック、ホイール ± 修飾キー)"
                                Click="EditMouse_Click">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Mouse}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Mouse}" Value="">
                                                <Setter Property="Text"       Value="—" />
                                                <Setter Property="Foreground" Value="#999" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <Button Grid.Column="3"
                                Style="{StaticResource BindingButtonStyle}"
                                Margin="4,2,0,2"
                                ToolTip="マウスジェスチャーを変更"
                                Click="EditGesture_Click">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Gesture}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Gesture}" Value="">
                                                <Setter Property="Text"       Value="—" />
                                                <Setter Property="Foreground" Value="#999" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="#F0F4F8"
                                    BorderBrush="#D8DEE3"
                                    BorderThickness="0,0,0,1"
                                    Padding="6,4">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource CategoryHeaderStyle}" />
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
        </ListView>

    </DockPanel>
</Window>
