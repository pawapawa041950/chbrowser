<Window x:Class="ChBrowser.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        xmlns:settings="clr-namespace:ChBrowser.Views.Settings"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
        Title="ChBrowser 設定"
        Width="820" Height="560"
        MinWidth="520" MinHeight="380"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 左ペインのカテゴリ ListBoxItem を薄いボタン風にスタイリング -->
        <Style x:Key="CategoryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"     Value="12,6" />
            <Setter Property="Margin"      Value="0,1" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background"  Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="3,0,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EAF1F8" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#CCE5FF" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#1E88E5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate: SelectedCategory.Name に応じて右ペインの中身を切替。
             カテゴリ追加 (お気に入り / タブ動作 等) は後続フェーズでここに追加する。 -->
        <DataTemplate x:Key="GeneralTemplate">    <settings:GeneralPanel /> </DataTemplate>
        <DataTemplate x:Key="NetworkTemplate">    <settings:NetworkPanel /> </DataTemplate>
        <DataTemplate x:Key="FavoritesTemplate">  <settings:FavoritesPanel /> </DataTemplate>
        <DataTemplate x:Key="BoardListTemplate">  <settings:BoardListPanel /> </DataTemplate>
        <DataTemplate x:Key="ThreadListTemplate"> <settings:ThreadListPanel /> </DataTemplate>
        <DataTemplate x:Key="ThreadTemplate">     <settings:ThreadPanel /> </DataTemplate>
        <DataTemplate x:Key="TabActionTemplate">  <settings:TabActionPanel /> </DataTemplate>
        <DataTemplate x:Key="ImageTemplate">      <settings:ImagePanel /> </DataTemplate>
        <DataTemplate x:Key="ViewerTemplate">     <settings:ViewerPanel /> </DataTemplate>
        <DataTemplate x:Key="DesignTemplate">     <settings:DesignPanel /> </DataTemplate>

        <!-- 未実装カテゴリ用 placeholder -->
        <DataTemplate x:Key="PlaceholderTemplate">
            <TextBlock Text="(このカテゴリは後続フェーズで実装されます)"
                       Foreground="#888"
                       FontStyle="Italic" />
        </DataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- 上部バナー: HiDPI / TimeoutSec 変更時に「再起動が必要」表示 -->
        <Border DockPanel.Dock="Top"
                Background="#FFF8DC"
                BorderBrush="#E6C660"
                BorderThickness="0,0,0,1"
                Padding="14,8"
                Visibility="{Binding RestartRequired, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="今すぐ再起動"
                        Padding="10,4"
                        Margin="12,0,0,0"
                        Command="{Binding RestartNowCommand}" />
                <TextBlock VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="変更を反映するにはアプリの再起動が必要です。" />
            </DockPanel>
        </Border>

        <!-- 下部: ボタン列 (即時反映なので閉じるのみ) -->
        <Border DockPanel.Dock="Bottom"
                Background="{x:Static SystemColors.ControlBrush}"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="閉じる"
                        Width="90"
                        IsCancel="True"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Border>

        <!-- 中央: 左カテゴリ列 + GridSplitter + 右設定ペイン -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColCategories" Width="200" MinWidth="140" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- 左ペイン: カテゴリ ListBox -->
            <Border Grid.Column="0"
                    Background="#F4F4F4"
                    BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                    BorderThickness="0,0,1,0">
                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource CategoryListItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsCategoryViewModel}">
                            <TextBlock Text="{Binding Name}" FontSize="13" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          Background="{x:Static SystemColors.ControlBrush}" />

            <!-- 右ペイン: ヘッダ + ContentControl で各パネル切替 -->
            <Grid Grid.Column="2" Background="#FFFFFF">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedCategory.Name}"
                                   FontSize="20"
                                   FontWeight="Light" />
                        <TextBlock Text="{Binding SelectedCategory.Description}"
                                   Foreground="#666"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20,16">
                    <!-- Content を SettingsViewModel 自体 ({Binding}) にすることで、
                         パネル内の {Binding HiDpiMode} 等が SettingsViewModel のプロパティに直接届く。
                         テンプレ切替は SelectedCategory.Name の DataTrigger で行う。 -->
                    <ContentControl x:Name="CategoryContentHost"
                                    Content="{Binding}">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate" Value="{StaticResource PlaceholderTemplate}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="全般">
                                        <Setter Property="ContentTemplate" Value="{StaticResource GeneralTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="通信">
                                        <Setter Property="ContentTemplate" Value="{StaticResource NetworkTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="お気に入り">
                                        <Setter Property="ContentTemplate" Value="{StaticResource FavoritesTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="板一覧">
                                        <Setter Property="ContentTemplate" Value="{StaticResource BoardListTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="スレッド一覧">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ThreadListTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="スレッド">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ThreadTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="タブ動作">
                                        <Setter Property="ContentTemplate" Value="{StaticResource TabActionTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="画像">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ImageTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="ビューア">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ViewerTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Name}" Value="デザイン編集">
                                        <Setter Property="ContentTemplate" Value="{StaticResource DesignTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </ScrollViewer>
            </Grid>
        </Grid>

    </DockPanel>
</Window>
