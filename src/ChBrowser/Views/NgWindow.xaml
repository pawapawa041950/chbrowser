<Window x:Class="ChBrowser.Views.NgWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:NgWindowViewModel}"
        Title="ChBrowser NG 設定"
        Width="980" Height="600"
        MinWidth="720" MinHeight="400"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <DockPanel LastChildFill="True">

        <!-- 下部: 保存・閉じる -->
        <Border DockPanel.Dock="Bottom"
                Background="{x:Static SystemColors.ControlBrush}"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="保存"
                        Width="90"
                        Margin="0,0,8,0"
                        Command="{Binding SaveCommand}" />
                <Button Content="閉じる"
                        Width="90"
                        IsCancel="True"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Border>

        <!-- 上部: 操作ボタン + DataGrid -->
        <DockPanel Margin="8" LastChildFill="True">
            <Border DockPanel.Dock="Top" Padding="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="ルール追加"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            Command="{Binding AddRuleCommand}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#666"
                               Text="板名を「なし (全板)」にすると全板で適用されます。" />
                </StackPanel>
            </Border>
            <DataGrid ItemsSource="{Binding Rules}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="28"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="有効" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          Click="EnableCheck_Click" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="板名" Width="240">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- 板名はクリックでモーダルピッカー (BoardPickerWindow) を開いて選択する。
                                     インライン ComboBox で起きていた「Reset で SelectedItem が消える」「IME が重い」「DisplayName 入力が transient 化する」
                                     系の問題を全部回避する設計。SelectedScope.DisplayName をボタンの表示テキストとして表示する。 -->
                                <Button Click="ScopeButton_Click"
                                        HorizontalContentAlignment="Left"
                                        Padding="6,2"
                                        Content="{Binding SelectedScope.DisplayName, FallbackValue='なし (全板)', TargetNullValue='なし (全板)'}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridComboBoxColumn Header="対象" Width="110"
                                            ItemsSource="{x:Static vm:NgWindowViewModel.TargetOptions}"
                                            DisplayMemberPath="Label"
                                            SelectedValuePath="Value"
                                            SelectedValueBinding="{Binding Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridComboBoxColumn Header="検索方式" Width="110"
                                            ItemsSource="{x:Static vm:NgWindowViewModel.MatchKindOptions}"
                                            DisplayMemberPath="Label"
                                            SelectedValuePath="Value"
                                            SelectedValueBinding="{Binding MatchKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="NG対象文字列" Width="*"
                                        Binding="{Binding Pattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTemplateColumn Header="期限" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- CheckBox + DatePicker は双方向に連動: 日付を選ぶと自動で CheckBox が ON、
                                     CheckBox を OFF にすると ExpiresAt = null。常に DatePicker は操作可能 (= disable しない)
                                     にして、ユーザがクリックすればすぐカレンダーが開くようにする。 -->
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding HasExpiry, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,4,0" />
                                    <DatePicker SelectedDate="{Binding ExpiresAt, Mode=TwoWay}"
                                                Width="140" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- ゴミ箱アイコン: Segoe MDL2 Assets / Segoe Fluent Icons の Delete (U+E74D)。
                                     Windows 10+ に標準搭載されているフォントなので追加配布は不要。 -->
                                <Button Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="13"
                                        Width="28" Height="22"
                                        ToolTip="このルールを削除"
                                        Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

    </DockPanel>
</Window>
