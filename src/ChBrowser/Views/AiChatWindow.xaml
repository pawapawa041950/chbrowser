<Window x:Class="ChBrowser.Views.AiChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AiChatViewModel}"
        Title="{Binding ThreadTitle, StringFormat='AI チャット — {0}'}"
        Width="520" Height="600"
        MinWidth="360" MinHeight="320"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- ヘッダ -->
            <RowDefinition Height="*" />     <!-- 会話表示 (WebView2) -->
            <RowDefinition Height="Auto" />  <!-- ステータス -->
            <RowDefinition Height="Auto" />  <!-- 入力欄 -->
        </Grid.RowDefinitions>

        <!-- ヘッダ: スレタイトル + 説明 -->
        <Border Grid.Row="0"
                Background="{x:Static SystemColors.ControlBrush}"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel>
                <TextBlock Text="{Binding ThreadTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="このスレッドの内容を文脈に LLM と会話します。"
                           Foreground="#666" FontSize="11" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- 会話表示: WebView2 (ai-chat.html シェル)。markdown はリアルタイムに HTML 化して表示する。 -->
        <wv2:WebView2 x:Name="TranscriptView"
                      Grid.Row="1"
                      DefaultBackgroundColor="White" />

        <!-- ステータス行 (応答待ち / エラー)。空文字なら非表示。 -->
        <Border Grid.Row="2"
                Background="#FFFDF0"
                BorderBrush="#E6D88A"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Border.Style>
                <Style TargetType="Border">
                    <!-- 既定は表示。StatusMessage が空のときだけ Collapsed にする。 -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#7A6A20" FontSize="11" />
        </Border>

        <!-- 入力欄: 既定 1 行表示、テキスト量に応じて自動拡張 (MinLines/MaxLines)。
             Shift+Enter で送信、通常 Enter は改行 (= IME 変換確定の誤送信もここで防ぐ)。
             TextBox 自身は枠なし (BorderThickness=0)、外側の Border で CornerRadius を持って角丸を出す。 -->
        <Border Grid.Row="3"
                Background="{x:Static SystemColors.ControlBrush}"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="8"
                        Background="White"
                        BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                        BorderThickness="1"
                        Padding="8,4"
                        VerticalAlignment="Bottom">
                    <TextBox x:Name="InputBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinLines="1" MaxLines="8"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                             KeyDown="InputBox_KeyDown"
                             ToolTip="Shift+Enter で送信 / Enter で改行" />
                </Border>

                <Button Grid.Column="1"
                        Content="送信"
                        Width="72"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        Padding="0,8"
                        IsDefault="False"
                        Command="{Binding SendCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>
