<UserControl x:Class="ChBrowser.Controls.SearchBoxToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <!-- 折りたたみ状態: 🔍 ボタンだけ表示。HorizontalAlignment=Right にして、host が広い領域を渡しても
             右端に張り付く (= 隣の他ボタン群の直左に近い位置に固定される) ようにする。
             host が狭い場合はそのまま自然サイズ (= 28px) を保つ。 -->
        <Button x:Name="ExpandButton"
                Style="{StaticResource ToolbarIconButton}"
                HorizontalAlignment="Right"
                Click="ExpandButton_Click">
            <TextBlock Text="🔍" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>

        <!-- 展開状態: × ボタンを Dock=Right (= host の幅が狭くても右端に必ず残る)、
             TextBox は LastChildFill で残り幅を取る。MinWidth は付けない (= host が狭ければ TextBox が縮む)。 -->
        <DockPanel x:Name="ExpandedRoot" Visibility="Collapsed" LastChildFill="True">
            <Button DockPanel.Dock="Right"
                    x:Name="CloseButton"
                    Style="{StaticResource ToolbarIconButton}"
                    Width="20"
                    Click="CloseButton_Click"
                    ToolTip="検索を閉じる">
                <TextBlock Text="✕" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <TextBox x:Name="SearchTextBox"
                     VerticalContentAlignment="Center"
                     MinWidth="40"
                     Margin="0,1"
                     Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl},
                                    UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     KeyDown="SearchTextBox_KeyDown" />
        </DockPanel>
    </Grid>
</UserControl>
