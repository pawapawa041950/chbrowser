<Window x:Class="ChBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChBrowser"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        xmlns:ctrl="clr-namespace:ChBrowser.Controls"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:conv="clr-namespace:ChBrowser.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="ChBrowser" Height="720" Width="1200"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:LogMarkStateToBrushConverter x:Key="LogMarkBrush" />

        <!-- 板一覧 WebView の右クリックで popup する ContextMenu (Phase 14a)。
             BoardListWebView_WebMessageReceived が JS の contextMenu メッセージを受けて、
             PlacementMode=MousePoint でこの ContextMenu を popup する。
             Tag に host/dir/name の組を入れた string を一時保存する。 -->
        <ContextMenu x:Key="BoardContextMenu" x:Shared="False">
            <MenuItem Header="お気に入りに追加" Click="AddBoardToFavorites_Click" />
        </ContextMenu>

        <!-- お気に入りペイン WebView (Phase 14b) のコンテキストメニュー群。
             FavoritesWebView_WebMessageReceived が contextMenu メッセージで開く対象を決め、
             Tag に対応する FavoriteRef を積んでから IsOpen=true で popup する。
             各 MenuItem の Click ハンドラは Tag 経由で操作対象 id を取り出す。 -->

        <ContextMenu x:Key="FavoriteFolderContextMenu" x:Shared="False">
            <MenuItem Header="新規フォルダ" Click="FavNewFolderHere_Click" />
            <MenuItem Header="名前変更"     Click="FavRename_Click" />
            <MenuItem Header="削除"         Click="FavDelete_Click" />
            <Separator />
            <MenuItem Header="上へ"         Click="FavMoveUp_Click" />
            <MenuItem Header="下へ"         Click="FavMoveDown_Click" />
        </ContextMenu>

        <ContextMenu x:Key="FavoriteBoardContextMenu" x:Shared="False">
            <MenuItem Header="削除" Click="FavDelete_Click" />
            <Separator />
            <MenuItem Header="上へ" Click="FavMoveUp_Click" />
            <MenuItem Header="下へ" Click="FavMoveDown_Click" />
        </ContextMenu>

        <ContextMenu x:Key="FavoriteThreadContextMenu" x:Shared="False">
            <MenuItem Header="削除" Click="FavDelete_Click" />
            <Separator />
            <MenuItem Header="上へ" Click="FavMoveUp_Click" />
            <MenuItem Header="下へ" Click="FavMoveDown_Click" />
        </ContextMenu>

        <ContextMenu x:Key="FavoriteRootContextMenu" x:Shared="False">
            <MenuItem Header="新規フォルダ (ルート直下)" Click="FavNewFolderRoot_Click" />
            <Separator />
            <MenuItem Header="全更新"                    Click="FavRefreshAll_Click" />
        </ContextMenu>

        <!-- ツールバー用アイコンボタン (Button をテンプレート化) -->
        <Style x:Key="ToolbarIconButton" TargetType="Button">
            <Setter Property="Width"               Value="28" />
            <Setter Property="Height"              Value="24" />
            <Setter Property="Padding"             Value="0" />
            <Setter Property="Margin"              Value="1,0" />
            <Setter Property="Background"          Value="Transparent" />
            <Setter Property="BorderBrush"         Value="Transparent" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EAF1F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#CCE5FF" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#88B0DD" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <DockPanel LastChildFill="True">

        <!-- メニューバー + アドレスバー (Phase 14)。
             DockPanel の LastChildFill=True を活かして、Menu (Dock=Left) が内容分の幅、最後の TextBox が残り全幅を占める。
             Chrome のオムニボックス的なレイアウト。 -->
        <DockPanel DockPanel.Dock="Top" LastChildFill="True">
            <Menu DockPanel.Dock="Left">
                <MenuItem Header="ファイル(_F)">
                <MenuItem Header="板一覧を更新(_U)"
                          Command="{Binding RefreshBoardListCommand}" />
                <MenuItem Header="新規スレッド作成(_N)..." />
                <Separator />
                <MenuItem Header="終了(_X)" Click="ExitMenu_Click" />
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="コピー(_C)" Command="ApplicationCommands.Copy" />
                <MenuItem Header="検索(_F)..." InputGestureText="Ctrl+F" />
                <MenuItem Header="URL をコピー(_U)" />
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="スクロールバートラック(_T)">
                    <MenuItem Header="既読/未読境界" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="人気レス" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="自分のレス" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="URL" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="画像" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="動画" IsCheckable="True" IsChecked="True" />
                </MenuItem>
                <Separator />
                <MenuItem Header="フォントサイズを大きく" />
                <MenuItem Header="フォントサイズを小さく" />
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <MenuItem Header="NG 設定(_N)..." Click="OpenNgWindow_Click" />
                <MenuItem Header="ショートカット &amp; ジェスチャー(_K)..." Click="OpenShortcutsWindow_Click" />
                <MenuItem Header="設定(_S)..." Click="OpenSettings_Click" />
                <Separator />
                <MenuItem Header="キャッシュをクリア" />
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)..." />
            </MenuItem>
            </Menu>
            <TextBox x:Name="AddressBar"
                     Margin="6,2,6,2"
                     Padding="4,3"
                     VerticalContentAlignment="Center"
                     PreviewKeyDown="AddressBar_PreviewKeyDown"
                     GotKeyboardFocus="AddressBar_GotKeyboardFocus"
                     LostKeyboardFocus="AddressBar_LostKeyboardFocus"
                     PreviewMouseLeftButtonDown="AddressBar_PreviewMouseLeftButtonDown">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AddressBarHasError}" Value="True">
                                <Setter Property="BorderBrush"    Value="#D33" />
                                <Setter Property="BorderThickness" Value="1.5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="ApplicationCommands.Cut" />
                        <MenuItem Command="ApplicationCommands.Copy" />
                        <MenuItem Command="ApplicationCommands.Paste" />
                        <Separator />
                        <MenuItem Header="貼り付けて移動(_G)" Click="AddressBarPasteAndGo_Click" />
                        <Separator />
                        <MenuItem Command="ApplicationCommands.SelectAll" />
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
        </DockPanel>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusPostCount" Text="-- レス" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusFetchTime" Text="取得 --:--" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding AboneStatus}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusThreadSize" Text="-- KB" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding DonguriStatus}" ToolTip="acorn (どんぐり) Cookie の経過時間と推定 Lv (5 分で 1 上昇 / 約 3 時間で失効)" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="StatusTabCount" Text="タブ 0" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="StatusCacheUsage" Text="キャッシュ 0 MB" />
            </StatusBarItem>
        </StatusBar>

        <!-- 3 ペイン: 左=板一覧、右上=スレ一覧、右下=スレ表示 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColBoardList" Width="200" MinWidth="120" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition x:Name="ColRight"     Width="*"   MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- 左ペイン: お気に入り (上) + 板一覧 (下)、GridSplitter で可変高さ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="RowFavorites" Height="200" MinHeight="80" />
                    <RowDefinition Height="4" />
                    <RowDefinition x:Name="RowBoardList" Height="*"   MinHeight="100" />
                </Grid.RowDefinitions>

                <!-- 上: お気に入り (Phase 14b で WebView 化)
                     コンテキストメニュー (フォルダ / 板 / スレ / ルート) は Window.Resources に定義済。
                     JS の contextmenu イベント → postMessage('contextMenu', target, id) → C# が
                     対応する ContextMenu を Tag に対象 id を積んで popup する。 -->
                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top"
                               Text="お気に入り"
                               Padding="6,4"
                               Background="{x:Static SystemColors.ControlBrush}"
                               FontWeight="SemiBold" />
                    <wv2:WebView2 x:Name="FavoritesWebView"
                                  ctrl:WebView2Helper.Html="{Binding FavoritesHtml}"
                                  ctrl:WebView2Helper.PaneConfigJson="{Binding FavoritesConfigJson}"
                                  WebMessageReceived="FavoritesWebView_WebMessageReceived" />
                </DockPanel>

                <GridSplitter Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Rows"
                              Background="{x:Static SystemColors.ControlBrush}" />

                <!-- 下: 板一覧 -->
                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top"
                               Text="板一覧"
                               Padding="6,4"
                               Background="{x:Static SystemColors.ControlBrush}"
                               FontWeight="SemiBold" />
                    <!-- 板一覧 WebView2 (Phase 14a)。
                         ContextMenu (お気に入りに追加) は Window.Resources の "BoardContextMenu" に
                         定義しておき、JS の contextmenu メッセージで PlacementMode=MousePoint で popup する。 -->
                    <wv2:WebView2 x:Name="BoardListWebView"
                                  ctrl:WebView2Helper.Html="{Binding BoardListHtml}"
                                  ctrl:WebView2Helper.PaneConfigJson="{Binding BoardListConfigJson}"
                                  WebMessageReceived="BoardListWebView_WebMessageReceived" />
                </DockPanel>
            </Grid>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{x:Static SystemColors.ControlBrush}" />

            <!-- 右ペイン: 上下分割 + 中央ツールバー -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="RowThreadList" Height="240" MinHeight="100" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="RowThreadView" Height="*"   MinHeight="200" />
                </Grid.RowDefinitions>

                <!-- 右上: スレ一覧タブ (1 タブ = 1 板) -->
                <TabControl Grid.Row="0"
                            x:Name="ThreadListPane"
                            ItemsSource="{Binding ThreadListTabs}"
                            SelectedItem="{Binding SelectedThreadListTab}"
                            BorderThickness="0"
                            GotKeyboardFocus="ThreadListPane_GotKeyboardFocus"
                            PreviewMouseLeftButtonDown="ThreadListPane_PreviewMouseLeftButtonDown">
                    <TabControl.ItemContainerStyle>
                        <!-- Phase 11c: タブ動作 (中クリック / 装飾付き左クリック / 左ダブルクリック) を捕捉。
                             子要素の Button (×) クリックは code-behind で除外する。 -->
                        <Style TargetType="TabItem">
                            <EventSetter Event="PreviewMouseDown"  Handler="ThreadListTabItem_PreviewMouseDown" />
                            <EventSetter Event="MouseDoubleClick"  Handler="ThreadListTabItem_MouseDoubleClick" />
                        </Style>
                    </TabControl.ItemContainerStyle>
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ThreadListTabViewModel}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="×"
                                        Command="{Binding CloseCommand}"
                                        Width="16" Height="16"
                                        Margin="6,0,0,0"
                                        Padding="0"
                                        FontSize="10"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="閉じる" />
                                <TextBlock Text="{Binding Header}" VerticalAlignment="Center" />
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:ThreadListTabViewModel}">
                            <wv2:WebView2 ctrl:WebView2Helper.Html="{Binding Html}"
                                          ctrl:WebView2Helper.LogMarkUpdate="{Binding LogMarkUpdate}"
                                          ctrl:WebView2Helper.PaneConfigJson="{Binding DataContext.ThreadListConfigJson, RelativeSource={RelativeSource AncestorType=Window}}"
                                          WebMessageReceived="ThreadListWebView_WebMessageReceived" />
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <GridSplitter Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Rows"
                              Background="{x:Static SystemColors.ControlBrush}" />

                <!-- 中央ツールバー (スレ表示操作用、今後ボタンを追加) -->
                <Border Grid.Row="2"
                        Background="{x:Static SystemColors.ControlBrush}"
                        BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel Margin="4,2">

                        <!-- 板アクション (新規スレ立て)。
                             SelectedThreadListTab が板タブ (Board != null) のときだけ有効。 -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedThreadListTab.IsBoardTab}" Value="True">
                                            <Setter Property="IsEnabled" Value="True" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button Style="{StaticResource ToolbarIconButton}"
                                    Click="NewThreadButton_Click"
                                    ToolTip="この板に新規スレッドを立てる">
                                <Grid Width="16" Height="16">
                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.4"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent"
                                          Data="M 3,3 L 11,3 L 13,5 L 13,13 L 3,13 Z M 8,7 L 8,11 M 6,9 L 10,9" />
                                </Grid>
                            </Button>
                            <Border Width="1"
                                    Margin="4,2"
                                    Background="{x:Static SystemColors.ControlDarkBrush}" />
                        </StackPanel>

                        <!-- スレ表示アクション (既存): SelectedThreadTab=null なら disabled -->
                        <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedThreadTab}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- 差分取得 (リフレッシュ) -->
                        <Button Style="{StaticResource ToolbarIconButton}"
                                Command="{Binding SelectedThreadTab.RefreshCommand}"
                                ToolTip="このスレの差分を取得 (新着レスを末尾に追加)">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.4"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M 13,8 A 5,5 0 1 0 8,3 M 8,3 L 11,3 M 8,3 L 8,6" />
                        </Button>

                        <!-- 書き込み (鉛筆アイコン) — Phase 8 -->
                        <Button Style="{StaticResource ToolbarIconButton}"
                                Command="{Binding SelectedThreadTab.WriteCommand}"
                                ToolTip="このスレに書き込む">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.4"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M 3,13 L 3,16 L 6,16 L 14,8 L 11,5 L 3,13 M 11,5 L 13,3 L 16,6 L 14,8" />
                        </Button>

                        <!-- 表示モード切替 (3 状態トグル: レス順 → ツリー(重複あり) → ツリー(重複なし) → ループ) -->
                        <Button Command="{Binding SelectedThreadTab.CycleViewModeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                    <Setter Property="ToolTip" Value="表示モードを切替" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}" Value="{x:Static vm:ThreadViewMode.Flat}">
                                            <Setter Property="ToolTip" Value="現在: レス順表示 (クリック → ツリー (重複あり))" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}" Value="{x:Static vm:ThreadViewMode.Tree}">
                                            <Setter Property="ToolTip" Value="現在: ツリー表示 (重複あり) (クリック → ツリー (重複なし))" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}" Value="{x:Static vm:ThreadViewMode.DedupTree}">
                                            <Setter Property="ToolTip" Value="現在: ツリー表示 (重複なし) (クリック → レス順表示)" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid Width="16" Height="20">
                                <!-- レス順アイコン -->
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M3,5 L13,5 M3,10 L13,10 M3,15 L13,15">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode, FallbackValue={x:Static vm:ThreadViewMode.Flat}}"
                                                             Value="{x:Static vm:ThreadViewMode.Flat}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <!-- ツリー (重複あり) アイコン -->
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M5,3 L5,17 M5,7 L11,7 M5,12 L11,12 M5,16 L11,16">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}"
                                                             Value="{x:Static vm:ThreadViewMode.Tree}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <!-- ツリー (重複なし) アイコン -->
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.4"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M3,3 L3,6 L6,6 L6,10 L9,10 L9,14 L12,14">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedThreadTab.ViewMode}"
                                                             Value="{x:Static vm:ThreadViewMode.DedupTree}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </Button>

                        <!-- ログ削除 (ゴミ箱アイコン) -->
                        <Button Style="{StaticResource ToolbarIconButton}"
                                Command="{Binding SelectedThreadTab.DeleteCommand}"
                                ToolTip="このスレのログを削除してタブを閉じる">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2"
                                  StrokeLineJoin="Round"
                                  Data="M6,3 L10,3 L10,5 L6,5 Z M3,5 L13,5 M5,5 L5,16 L11,16 L11,5 M7,8 L7,13 M9,8 L9,13" />
                        </Button>

                        <!-- お気に入りトグル (★)。
                             SelectedThreadTab.IsFavorited=true のとき押下表示 (背景強調)。
                             クリックで toggle (押すと add or remove) する。 -->
                        <Button Command="{Binding SelectedThreadTab.AddToFavoritesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                    <Setter Property="ToolTip" Value="このスレをお気に入りに追加" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedThreadTab.IsFavorited}" Value="True">
                                            <Setter Property="ToolTip"     Value="このスレをお気に入りから外す" />
                                            <Setter Property="Background"  Value="#CCE5FF" />
                                            <Setter Property="BorderBrush" Value="#88B0DD" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="★" FontSize="14" Foreground="#e6b800"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 右下: スレ本文エリア
                     各タブが専属の WebView2 を持ち、タブ切替は Visibility 切替だけで済む。
                     - 上段 (TabControl): タブ見出しと選択ロジックのみ。Template で content area を排除し
                       TabPanel だけを描画させる。
                     - 下段 (ItemsControl): 全 ThreadTabViewModel に対して WebView2 を 1 つずつ生成し、
                       Grid で重ねて配置。Visibility を IsSelected に bind して選択タブだけ可視にする。 -->
                <Grid Grid.Row="3"
                      x:Name="ThreadPane"
                      GotKeyboardFocus="ThreadPane_GotKeyboardFocus"
                      PreviewMouseLeftButtonDown="ThreadPane_PreviewMouseLeftButtonDown">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl Grid.Row="0"
                                ItemsSource="{Binding ThreadTabs}"
                                SelectedItem="{Binding SelectedThreadTab}"
                                BorderThickness="0">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <TabPanel IsItemsHost="True"
                                          Background="{x:Static SystemColors.ControlBrush}" />
                            </ControlTemplate>
                        </TabControl.Template>
                        <TabControl.ItemContainerStyle>
                            <!-- Phase 11c: タブ動作 -->
                            <Style TargetType="TabItem">
                                <EventSetter Event="PreviewMouseDown" Handler="ThreadTabItem_PreviewMouseDown" />
                                <EventSetter Event="MouseDoubleClick" Handler="ThreadTabItem_MouseDoubleClick" />
                            </Style>
                        </TabControl.ItemContainerStyle>
                        <TabControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ThreadTabViewModel}">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="×"
                                            Command="{Binding CloseCommand}"
                                            Width="16" Height="16"
                                            Margin="6,0,0,0"
                                            Padding="0"
                                            FontSize="10"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="閉じる" />
                                    <!-- 状態マーク (スレ一覧と同じ意味)。お気に入り済みなら背景に薄い ★。 -->
                                    <Grid DockPanel.Dock="Left" Width="14" Height="14" Margin="2,0,4,0" VerticalAlignment="Center">
                                        <TextBlock Text="★" FontSize="14" Foreground="#B3E6B800"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding IsFavorited, Converter={StaticResource BoolToVis}}" />
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Fill="{Binding State, Converter={StaticResource LogMarkBrush}}" />
                                    </Grid>
                                    <TextBlock Text="{Binding Header}"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Header}" />
                                </DockPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                    </TabControl>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ThreadTabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ThreadTabViewModel}">
                                <wv2:WebView2 ctrl:WebView2Helper.AppendBatch="{Binding LatestAppendBatch}"
                                              ctrl:WebView2Helper.ViewMode="{Binding ViewMode}"
                                              ctrl:WebView2Helper.ThreadConfigJson="{Binding DataContext.ThreadConfigJson, RelativeSource={RelativeSource AncestorType=Window}}"
                                              WebMessageReceived="ThreadViewWebView_WebMessageReceived"
                                              Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Grid>

    </DockPanel>
</Window>
