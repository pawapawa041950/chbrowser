<Window x:Class="ChBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChBrowser"
        xmlns:vm="clr-namespace:ChBrowser.ViewModels"
        xmlns:ctrl="clr-namespace:ChBrowser.Controls"
        xmlns:models="clr-namespace:ChBrowser.Models"
        xmlns:panes="clr-namespace:ChBrowser.Views.Panes"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:conv="clr-namespace:ChBrowser.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="ChBrowser" Height="720" Width="1200"
        UseLayoutRounding="True">

    <DockPanel LastChildFill="True">

        <!-- メニューバー + アドレスバー (Phase 14)。
             Background を入れて、アドレスバーの白いテキスト枠の周囲がグレーになるようにする (Phase 23: 統一見た目)。
             TextBox 自体の中身は WPF 既定の白のまま。 -->
        <DockPanel DockPanel.Dock="Top" LastChildFill="True"
                   Background="{x:Static SystemColors.ControlBrush}">
            <Menu DockPanel.Dock="Left">
                <MenuItem Header="ファイル(_F)">
                    <MenuItem Header="板一覧を更新(_U)" Command="{Binding RefreshBoardListCommand}" />
                    <MenuItem Header="お気に入りチェック(_C)" Click="MenuFavCheckUpdates_Click" />
                    <MenuItem Header="新規スレッド作成(_N)..." />
                    <Separator />
                    <MenuItem Header="終了(_X)" Click="ExitMenu_Click" />
                </MenuItem>
                <MenuItem Header="編集(_E)">
                    <MenuItem Header="コピー(_C)" Command="ApplicationCommands.Copy" />
                    <MenuItem Header="検索(_F)..." InputGestureText="Ctrl+F" />
                    <MenuItem Header="URL をコピー(_U)" />
                </MenuItem>
                <MenuItem Header="表示(_V)">
                    <MenuItem Header="スクロールバートラック(_T)">
                        <MenuItem Header="既読/未読境界" IsCheckable="True" IsChecked="True" />
                        <MenuItem Header="人気レス" IsCheckable="True" IsChecked="True" />
                        <MenuItem Header="自分のレス" IsCheckable="True" IsChecked="True" />
                        <MenuItem Header="URL" IsCheckable="True" IsChecked="True" />
                        <MenuItem Header="画像" IsCheckable="True" IsChecked="True" />
                        <MenuItem Header="動画" IsCheckable="True" IsChecked="True" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="フォントサイズを大きく" />
                    <MenuItem Header="フォントサイズを小さく" />
                    <Separator />
                    <MenuItem Header="ログペイン(_L)" IsCheckable="True"
                              IsChecked="{Binding IsLogPaneVisible, Mode=TwoWay}" />
                    <MenuItem Header="ペインレイアウトをリセット(_R)" Click="ResetLayoutMenu_Click" />
                </MenuItem>
                <MenuItem Header="ツール(_T)">
                    <MenuItem Header="NG 設定(_N)..." Click="OpenNgWindow_Click" />
                    <MenuItem Header="ショートカット &amp; ジェスチャー(_K)..." Click="OpenShortcutsWindow_Click" />
                    <MenuItem Header="設定(_S)..." Click="OpenSettings_Click" />
                    <Separator />
                    <MenuItem Header="キャッシュをクリア" />
                </MenuItem>
                <MenuItem Header="ヘルプ(_H)">
                    <MenuItem Header="バージョン情報(_A)..." />
                </MenuItem>
            </Menu>
            <TextBox x:Name="AddressBar"
                     Margin="6,2,6,2"
                     Padding="4,3"
                     VerticalContentAlignment="Center"
                     PreviewKeyDown="AddressBar_PreviewKeyDown"
                     GotKeyboardFocus="AddressBar_GotKeyboardFocus"
                     LostKeyboardFocus="AddressBar_LostKeyboardFocus"
                     PreviewMouseLeftButtonDown="AddressBar_PreviewMouseLeftButtonDown">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AddressBarHasError}" Value="True">
                                <Setter Property="BorderBrush"    Value="#D33" />
                                <Setter Property="BorderThickness" Value="1.5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="ApplicationCommands.Cut" />
                        <MenuItem Command="ApplicationCommands.Copy" />
                        <MenuItem Command="ApplicationCommands.Paste" />
                        <Separator />
                        <MenuItem Header="貼り付けて移動(_G)" Click="AddressBarPasteAndGo_Click" />
                        <Separator />
                        <MenuItem Command="ApplicationCommands.SelectAll" />
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
        </DockPanel>

        <!-- 上ボタンバー (= Chrome ブックマークバー風)。
             お気に入り直下に「上ボタン」フォルダがあり、その中に項目が入っている時だけ表示。
             空 / フォルダ無しなら Collapsed (= 高さゼロでスペース取らない)。 -->
        <panes:TopButtonsPane DockPanel.Dock="Top">
            <panes:TopButtonsPane.Style>
                <Style TargetType="panes:TopButtonsPane">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTopButtonsBarVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </panes:TopButtonsPane.Style>
        </panes:TopButtonsPane>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusPostCount" Text="-- レス" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusFetchTime" Text="取得 --:--" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding AboneStatus}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock x:Name="StatusThreadSize" Text="-- KB" /></StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding GestureStatus}" Foreground="#1E88E5" FontWeight="SemiBold" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding DonguriStatus}" ToolTip="acorn (どんぐり) Cookie の経過時間と推定 Lv (5 分で 1 上昇 / 約 3 時間で失効)" />
            </StatusBarItem>
            <Separator />
            <!-- どんぐりメール認証のログイン状態 (空文字なら表示しない、メアド未設定時は表示無し) -->
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding DonguriLoginStatus}"
                           ToolTip="どんぐりメール認証のログイン状態 (設定 → 認証 で構成)" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right"><TextBlock x:Name="StatusTabCount"   Text="タブ 0" /></StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right"><TextBlock x:Name="StatusCacheUsage" Text="キャッシュ 0 MB" /></StatusBarItem>
        </StatusBar>

        <!-- 4 ペインを binary tree レイアウトで配置するカスタム Panel (Phase 23 docking)。
             各 UserControl のヘッダ部分がドラッグハンドルになっており、別ペインにドロップすると
             その配置 (上/下/左/右) に応じてレイアウトツリーが書き換えられる。 -->
        <ctrl:PaneLayoutPanel x:Name="LayoutHost"
                              LayoutChanged="LayoutHost_LayoutChanged">
            <panes:FavoritesPane     x:Name="FavoritesPaneCtrl"     ctrl:PaneLayoutPanel.PaneId="{x:Static models:PaneId.Favorites}" />
            <panes:BoardListPane     x:Name="BoardListPaneCtrl"     ctrl:PaneLayoutPanel.PaneId="{x:Static models:PaneId.BoardList}" />
            <panes:ThreadListPane    x:Name="ThreadListPaneCtrl"    ctrl:PaneLayoutPanel.PaneId="{x:Static models:PaneId.ThreadList}" />
            <panes:ThreadDisplayPane x:Name="ThreadDisplayPaneCtrl" ctrl:PaneLayoutPanel.PaneId="{x:Static models:PaneId.ThreadDisplay}" />
        </ctrl:PaneLayoutPanel>
    </DockPanel>
</Window>
